# Pressable — sugestão Enrico (pastebin.com/7Md4qX62)
# Testar só no clone primeiro; snapshot sem tráfego real.

# 1. Protect the entire plugins and themes directories from being touched
!wp-content/plugins/*/
!wp-content/themes/*/

# 2. Protect specific standalone files (like the cache drops)
!wp-content/plugins/*.php

# 3. Allow your Git-synced items to be updated/overwritten
wp-content/plugins/planetaexo-unificado-plugin/
wp-content/themes/planetaexo-template/

# 4. Standard system ignores
wp-content/mu-plugins/
