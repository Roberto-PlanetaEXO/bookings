# Mesmas regras que /.deployignore — caminhos relativos a wp-content/
# (quando "Repository directory" = wp-content no Pressable)

# 1. Protect plugins/ and themes/ subdirectories
!plugins/*/
!themes/*/

# 2. Standalone .php in plugins root (object-cache, etc.)
!plugins/*.php

# 3. Allow Git-synced folders to receive updates from repo
plugins/planetaexo-unificado-plugin/
themes/planetaexo-template/

# 4. Standard
mu-plugins/
